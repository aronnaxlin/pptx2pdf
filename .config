# pptx2pdf Project Configuration

## Project Information
PROJECT_NAME="pptx2pdf"
VERSION="1.0.0"
AUTHOR="Alma AI"
DESCRIPTION="Professional PPTX to PDF conversion tool"

## Directories
BIN_DIR="bin"
SRC_DIR="src"
DOCS_DIR="docs"
EXAMPLES_DIR="examples"
SCRIPTS_DIR="scripts"

## Dependencies
REQUIRED_COMMANDS="soffice"
OPTIONAL_COMMANDS="shellcheck python3 node"

## Installation
INSTALL_TARGET="$HOME/.local/bin"
CONFIG_FILES=("$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile")

## Development
TEST_DIR="examples/test_files"
OUTPUT_DIR="examples/test_output"
PACKAGE_FORMATS=("tar.gz")

## Supported Platforms
PLATFORMS=("darwin" "linux")
SHELLS=("zsh" "bash")